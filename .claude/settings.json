{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/check-env.sh"
          },
          {
            "type": "command",
            "command": "pip install -r requirements.txt -q 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
